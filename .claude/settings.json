{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/tools/session_guard_lite.py\"",
            "timeout": 15,
            "statusMessage": "session_guard: rules, pings, stale artifacts..."
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/compact_reinject.py\"",
            "timeout": 10,
            "statusMessage": "Re-injecting critical context after compaction..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/single_instance.py\"",
            "timeout": 10,
            "statusMessage": "Checking for duplicate sessions..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/rules_memory_check.py\"",
            "timeout": 10,
            "statusMessage": "Verifying rules, hooks, and skills..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/block_find_exe.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_commit_guard.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/xplat_guard.py\"",
            "timeout": 35,
            "statusMessage": "XPLAT-001: checking cross-platform compliance..."
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/hook_chain_guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/strictmode_check.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/com_lifecycle_check.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/branch_naming.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/backup_config.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/secret_scanner.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/upnote_reminder.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/cross_repo_ping.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_action_notify.py\"",
            "timeout": 20,
            "statusMessage": "Checking if GitHub notification needed..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto_ping.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/config_audit.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/ping_check.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto_commit.py\"",
            "timeout": 20
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:community.esri.com)",
      "WebFetch(domain:www.sciencedirect.com)",
      "WebFetch(domain:www.uoguelph.ca)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:scholar.google.com)",
      "WebFetch(domain:www.researchgate.net)",
      "WebFetch(domain:networkx.org)",
      "WebFetch(domain:www.epa.gov)",
      "WebFetch(domain:doi.org)",
      "WebFetch(domain:www.usgs.gov)",
      "WebFetch(domain:www.hec.usace.army.mil)",
      "WebFetch(domain:onlinelibrary.wiley.com)",
      "WebFetch(domain:swmm5.org)",
      "WebFetch(domain:www.tandfonline.com)",
      "WebFetch(domain:pcswmm.com)",
      "WebFetch(domain:hydrology.usu.edu)",
      "WebFetch(domain:www.civil.uwaterloo.ca)",
      "WebFetch(domain:www.mdpi.com)",
      "WebFetch(domain:www.transportation.gov)",
      "WebFetch(domain:rosap.ntl.bts.gov)",
      "WebFetch(domain:link.springer.com)",
      "WebFetch(domain:www.nrcs.usda.gov)",
      "WebFetch(domain:www.linkedin.com)",
      "WebFetch(domain:www.vdot.virginia.gov)",
      "WebFetch(domain:docs.whiteboxtoolset.com)",
      "WebFetch(domain:www.wsdot.wa.gov)",
      "WebFetch(domain:www.dot.state.mn.us)",
      "WebFetch(domain:pro.arcgis.com)",
      "WebFetch(domain:desktop.arcgis.com)",
      "WebFetch(domain:giswqs.github.io)",
      "WebFetch(domain:www.eng.uwo.ca)",
      "WebFetch(domain:whiteboxgeo.com)"
    ],
    "additionalDirectories": [
      "~/.claude/memory"
    ]
  }
}
